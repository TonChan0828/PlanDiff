# Supabase(ダッシュボード > Settings > API から取得)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# サーバー専用。クライアントに絶対に露出させない(NEXT_PUBLIC_ を付けない)
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth(Google Cloud Console。Supabase Auth の Google プロバイダにも設定)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 結合テスト用: RLSを介さないDB直接検証(ローカルSupabaseのみ。npx supabase status で確認)
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
